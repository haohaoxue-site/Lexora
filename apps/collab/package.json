    "@hocuspocus/server": "^4.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "catalog:",
    "fastify": "catalog:",
    "ioredis": "catalog:",
    "pg": "^8.20.0",
    "pino": "catalog:",
    "prisma": "^7.8.0",
    "yjs": "^13.6.30",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@types/node": "catalog:",
    "pino-pretty": "catalog:",
    "tsdown": "^0.21.10"
  }
