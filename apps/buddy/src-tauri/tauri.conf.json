{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lexora Buddy",
  "version": "0.1.0",
  "identifier": "com.lexora.buddy",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "panel",
        "title": "Lexora",
        "url": "/panel",
        "width": 1280,
        "height": 680,
        "minWidth": 980,
        "minHeight": 520,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "resizable": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      },
      {
        "label": "chat",
        "title": "Lexora Chat",
        "url": "/chat",
        "width": 560,
        "height": 640,
        "minWidth": 500,
        "minHeight": 560,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "resizable": true,
        "maximizable": false,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libgtk-layer-shell0"
        ]
      }
    },
    "targets": "all"
  }
}
