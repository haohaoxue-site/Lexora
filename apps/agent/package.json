{
  "name": "@haohaoxue/samepage-agent",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node --watch --import dotenv/config --import @swc-node/register/esm-register src/main.ts",
    "build": "tsdown",
    "start": "node --import dotenv/config dist/main.mjs",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit -p tsconfig.json --pretty false",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests"
  },
  "dependencies": {
    "@haohaoxue/samepage-contracts": "workspace:*",
    "@haohaoxue/samepage-shared": "workspace:*",
    "@langchain/anthropic": "^1.3.28",
    "@langchain/core": "^1.1.42",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint-postgres": "1.0.1",
    "@langchain/openai": "^1.4.5",
    "dotenv": "catalog:",
    "fastify": "catalog:",
    "ioredis": "catalog:",
    "pino": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@types/node": "catalog:",
    "pino-pretty": "catalog:",
    "tsdown": "^0.21.10"
  }
}
