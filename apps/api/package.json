{
  "name": "@haohaoxue/samepage-api",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "pnpm prisma:sync",
    "predev:debug": "pnpm prisma:sync",
    "dev": "node --watch --import @swc-node/register/esm-register src/main.ts",
    "dev:debug": "node --watch --inspect --import @swc-node/register/esm-register src/main.ts",
    "dev:prod": "node dist/main.js",
    "prebuild": "prisma generate",
    "build": "tsdown",
    "system-admin:reset-password": "node dist/cli/reset-system-admin-password.mjs",
    "system-admin:reset-password:dev": "node --import dotenv/config --import @swc-node/register/esm-register src/cli/reset-system-admin-password.ts",
    "lint:fix": "eslint . --fix",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push",
    "prisma:sync": "prisma migrate deploy && prisma generate",
    "type-check": "tsc --noEmit -p tsconfig.json --pretty false && tsc --noEmit -p tsconfig.spec.json --pretty false",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@haohaoxue/samepage-contracts": "workspace:*",
    "@haohaoxue/samepage-shared": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tencent-weixin/openclaw-weixin": "^2.4.4",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie": "^1.1.1",
    "dotenv": "catalog:",
    "fastify": "catalog:",
    "ioredis": "catalog:",
    "jose": "^6.2.3",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^8.0.7",
    "openid-client": "^6.8.4",
    "pg": "^8.20.0",
    "pino": "catalog:",
    "pino-http": "^11.0.0",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.32",
    "@types/node": "catalog:",
    "@types/supertest": "^7.2.0",
    "globals": "^17.5.0",
    "pino-pretty": "catalog:",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "tsdown": "^0.21.10",
    "typescript": "catalog:"
  }
}
