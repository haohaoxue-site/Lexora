enum ChatSessionMessageRole {
  USER
  ASSISTANT
}

enum ChatSessionMessageStatus {
  STREAMING
  COMPLETED
  FAILED
}

enum ChatSessionMessagePartType {
  REASONING
  TEXT
  TOOL_CALL
  TOOL_RESULT
  SOURCE
  CITATION
}

model ChatSession {
  id                 String               @id @default(uuid())
  userId             String
  title              String
  selectedProviderId String?
  selectedModelId    String?
  historyVersion     Int                  @default(0)
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages           ChatSessionMessage[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?

  @@index([userId, updatedAt])
  @@index([selectedProviderId])
}

model ChatSessionMessage {
  id          String                   @id @default(uuid())
  sessionId   String
  role        ChatSessionMessageRole
  status      ChatSessionMessageStatus @default(COMPLETED)
  content     String
  order       Int
  agentRunId  String?
  metadata    Json?
  completedAt DateTime?
  session     ChatSession              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  parts       ChatSessionMessagePart[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  deletedAt   DateTime?

  @@unique([sessionId, order])
  @@index([agentRunId])
  @@index([sessionId, createdAt])
}

model ChatSessionMessagePart {
  id        String                     @id @default(uuid())
  messageId String
  type      ChatSessionMessagePartType
  text      String                     @default("")
  order     Int
  metadata  Json?
  message   ChatSessionMessage        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
  deletedAt DateTime?

  @@unique([messageId, order])
  @@index([messageId, type])
}
