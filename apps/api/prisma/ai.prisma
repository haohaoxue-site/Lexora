enum AiProviderScope {
  SYSTEM
  USER
}

enum AiProviderEndpointMode {
  FIXED
  CUSTOM
}

enum AiProviderAuthMode {
  API_KEY
  BEARER
  NONE
}

enum AiProviderVisibility {
  ALL_USERS
}

enum AiProviderSource {
  PRESET
  COMPATIBLE
}

enum AiModelType {
  CHAT
  EMBEDDING
  RERANK
  IMAGE
}

enum AiModelCapability {
  STREAMING
  VISION
  TOOL_CALL
  REASONING
  JSON_MODE
}

enum AiAnchorKind {
  BLOCK_INSERT
  TEXT_SELECTION
}

enum AiSessionStatus {
  PENDING
  RUNNING
  READY
  ACCEPTED
  REJECTED
  FAILED
}

enum AiRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AiCandidateStatus {
  COMPLETED
  ACCEPTED
  REJECTED
}

model AiProvider {
  id              String                 @id @default(uuid())
  scope           AiProviderScope
  ownerUserId     String?
  ownerKey        String
  identityKey     String
  source          AiProviderSource
  providerKey     String
  providerName    String
  adapterKey      String
  endpointMode    AiProviderEndpointMode
  endpoint        String?
  authMode        AiProviderAuthMode
  apiKeyEncrypted String?
  enabled         Boolean                @default(false)
  visibility      AiProviderVisibility   @default(ALL_USERS)
  ownerUser       User?                  @relation("AiProviderOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  models          AiProviderModel[]
  defaultPolicies AiDefaultModelPolicy[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  updatedBy       String?
  updatedByUser   User?                  @relation("AiProviderUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  deletedAt       DateTime?

  @@unique([ownerKey, identityKey])
  @@index([scope, enabled])
  @@index([ownerUserId, enabled])
  @@index([ownerKey, providerKey])
  @@index([providerKey])
  @@index([updatedBy])
}

model AiProviderModel {
  id              String              @id @default(uuid())
  providerId      String
  modelId         String
  modelName       String
  modelType       AiModelType
  capabilities    AiModelCapability[]
  contextWindow   Int?
  maxOutputTokens Int?
  enabled         Boolean             @default(true)
  provider        AiProvider          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  updatedBy       String?
  updatedByUser   User?               @relation("AiProviderModelUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  deletedAt       DateTime?

  @@unique([providerId, modelId])
  @@index([providerId, enabled])
  @@index([modelType])
  @@index([updatedBy])
}

model AiDefaultModelPolicy {
  id            String     @id @default(uuid())
  userId        String
  intentKey     String
  providerId    String
  modelId       String
  user          User       @relation("AiDefaultModelPolicyUser", fields: [userId], references: [id], onDelete: Cascade)
  provider      AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  updatedBy     String?
  updatedByUser User?      @relation("AiDefaultModelPolicyUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  deletedAt     DateTime?

  @@unique([userId, intentKey])
  @@index([providerId])
  @@index([updatedBy])
}

model AiSession {
  id                     String          @id @default(uuid())
  documentId             String
  workflowKey            String
  prompt                 String
  anchorKind             AiAnchorKind
  anchor                 Json
  baseProjectionRevision Int
  status                 AiSessionStatus @default(PENDING)
  currentRunId           String?
  acceptedCandidateId    String?
  document               Document        @relation("AiSessionDocument", fields: [documentId], references: [id], onDelete: Cascade)
  runs                   AiRun[]         @relation("AiRunSession")
  candidates             AiCandidate[]   @relation("AiCandidateSession")
  currentRun             AiRun?          @relation("AiSessionCurrentRun", fields: [currentRunId], references: [id], onDelete: SetNull)
  acceptedCandidate      AiCandidate?    @relation("AiSessionAcceptedCandidate", fields: [acceptedCandidateId], references: [id], onDelete: SetNull)
  createdAt              DateTime        @default(now())
  createdBy              String
  createdByUser          User            @relation("AiSessionCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  updatedAt              DateTime        @updatedAt
  updatedBy              String?
  updatedByUser          User?           @relation("AiSessionUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  deletedAt              DateTime?

  @@index([documentId, createdAt])
  @@index([createdBy, createdAt])
  @@index([status])
  @@index([currentRunId])
  @@index([acceptedCandidateId])
  @@index([updatedBy])
}

model AiRun {
  id                  String        @id @default(uuid())
  sessionId           String
  agentRunId          String        @unique
  workflowKey         String
  modelTargetSnapshot Json?
  status              AiRunStatus   @default(PENDING)
  session             AiSession     @relation("AiRunSession", fields: [sessionId], references: [id], onDelete: Cascade)
  currentForSessions  AiSession[]   @relation("AiSessionCurrentRun")
  candidates          AiCandidate[] @relation("AiCandidateRun")
  createdAt           DateTime      @default(now())
  createdBy           String
  createdByUser       User          @relation("AiRunCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  updatedAt           DateTime      @updatedAt
  updatedBy           String?
  updatedByUser       User?         @relation("AiRunUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  deletedAt           DateTime?

  @@index([sessionId, createdAt])
  @@index([workflowKey, status])
  @@index([createdBy, createdAt])
  @@index([updatedBy])
}

model AiCandidate {
  id                  String            @id @default(uuid())
  sessionId           String
  runId               String
  contentText         String
  plainText           String?
  status              AiCandidateStatus @default(COMPLETED)
  acceptedAt          DateTime?
  session             AiSession         @relation("AiCandidateSession", fields: [sessionId], references: [id], onDelete: Cascade)
  run                 AiRun             @relation("AiCandidateRun", fields: [runId], references: [id], onDelete: Cascade)
  acceptedForSessions AiSession[]       @relation("AiSessionAcceptedCandidate")
  createdAt           DateTime          @default(now())
  createdBy           String
  createdByUser       User              @relation("AiCandidateCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  updatedAt           DateTime          @updatedAt
  updatedBy           String?
  updatedByUser       User?             @relation("AiCandidateUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  deletedAt           DateTime?

  @@index([sessionId, createdAt])
  @@index([runId])
  @@index([status])
  @@index([createdBy, createdAt])
  @@index([updatedBy])
}
