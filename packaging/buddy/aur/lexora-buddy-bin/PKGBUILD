# Maintainer: Lexora maintainers

pkgname=lexora-buddy-bin
pkgver=0.1.0
pkgrel=2
pkgdesc="Desktop pet and local agent companion for Lexora"
arch=('x86_64')
url="https://github.com/haohaoxue-site/Lexora"
license=('AGPL-3.0-only')
depends=(
  'cairo'
  'desktop-file-utils'
  'gdk-pixbuf2'
  'glib2'
  'gtk-layer-shell'
  'gtk3'
  'hicolor-icon-theme'
  'libsoup3'
  'pango'
  'webkit2gtk-4.1'
)
provides=('lexora-buddy')
conflicts=('lexora-buddy')
options=('!strip' '!debug')
install="${pkgname}.install"
source_x86_64=("lexora-buddy-${pkgver}-amd64.deb::${url}/releases/download/v${pkgver}/Lexora%20Buddy_${pkgver}_amd64.deb")
sha256sums_x86_64=('1e5b5991534e35740106e93f45411e7d6964b91433621377f7fca94d5a372a74')

package() {
  local data_archive

  bsdtar --no-same-owner -xf "${srcdir}/lexora-buddy-${pkgver}-amd64.deb" -C "${srcdir}"
  data_archive="$(find "${srcdir}" -maxdepth 1 -name 'data.tar.*' -print -quit)"
  bsdtar --no-same-owner -xf "${data_archive}" -C "${pkgdir}"
}
