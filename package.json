{
  "name": "@haohaoxue/lexora",
  "type": "module",
  "version": "1.0.0",
  "private": "true",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11.5.0"
  },
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:infra": "docker compose -f infrastructure/compose.dev.yml up -d",
    "dev:infra:down": "docker compose -f infrastructure/compose.dev.yml down",
    "dev:db:sync": "pnpm --filter @haohaoxue/lexora-api prisma:sync",
    "dev:db:reset": "pnpm --filter @haohaoxue/lexora-api exec prisma db push --force-reset",
    "dev:web": "pnpm --filter @haohaoxue/lexora-web dev",
    "dev:api": "pnpm --filter @haohaoxue/lexora-api dev",
    "dev:agent": "pnpm --filter @haohaoxue/lexora-agent dev",
    "dev:collab": "pnpm --filter @haohaoxue/lexora-collab dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r --parallel --if-present test:watch",
    "lint": "eslint apps packages",
    "lint:fix": "pnpm -r lint:fix",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "eslint": "^10.2.1",
    "typescript": "catalog:",
    "vitest": "^4.1.5"
  }
}
