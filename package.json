{
  "name": "@haohaoxue/lexora",
  "type": "module",
  "version": "1.0.0",
  "private": "true",
  "packageManager": "pnpm@11.5.0",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11.5.0"
  },
  "scripts": {
    "predev": "pnpm dev:env",
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:env": "node infrastructure/scripts/sync-dev-env.mjs",
    "dev:infra": "docker compose --env-file infrastructure/.env -f infrastructure/compose.dev.yml up -d",
    "dev:infra:down": "docker compose -f infrastructure/compose.dev.yml down",
    "predev:db:sync": "pnpm dev:env",
    "dev:db:sync": "pnpm --filter @haohaoxue/lexora-api prisma:sync",
    "predev:db:reset": "pnpm dev:env",
    "dev:db:reset": "pnpm --filter @haohaoxue/lexora-api exec prisma db push --force-reset",
    "predev:api": "pnpm dev:env",
    "dev:web": "pnpm --filter @haohaoxue/lexora-web dev",
    "dev:api": "pnpm --filter @haohaoxue/lexora-api dev",
    "predev:agent": "pnpm dev:env",
    "dev:agent": "pnpm --filter @haohaoxue/lexora-agent dev",
    "dev:buddy": "pnpm --filter @lexora/buddy dev",
    "predev:collab": "pnpm dev:env",
    "dev:collab": "pnpm --filter @haohaoxue/lexora-collab dev",
    "build": "pnpm -r --if-present build",
    "build:buddy:arch": "RUST_MIN_STACK=16777216 pnpm --filter @lexora/buddy tauri build --ci --bundles deb",
    "buddy:version:check": "node packaging/buddy/release/buddy-version.mjs --check",
    "buddy:version:set": "node packaging/buddy/release/buddy-version.mjs --set",
    "check:buddy": "node packaging/buddy/release/preflight.mjs",
    "check:buddy:delivery": "node packaging/buddy/release/verify-delivery-scope.mjs",
    "check:buddy:delivery:list": "node packaging/buddy/release/verify-delivery-scope.mjs --list",
    "check:buddy:external": "node packaging/buddy/release/verify-external-readiness.mjs",
    "check:buddy:external:template": "node packaging/buddy/release/verify-external-readiness.mjs --print-evidence-template",
    "check:buddy:asset": "node packaging/buddy/release/verify-remote-asset.mjs",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r --parallel --if-present test:watch",
    "lint": "eslint apps packages",
    "lint:fix": "pnpm -r lint:fix",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "eslint": "^10.2.1",
    "typescript": "catalog:",
    "vitest": "^4.1.5"
  }
}
